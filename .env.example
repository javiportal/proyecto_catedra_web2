# La Cuponera — Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and must NEVER be committed.
#
# Where to find these values:
#   Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# ⚠️  Use the "anon / public" key — NOT the "service_role" key.
# The service_role key bypasses ALL Row Level Security policies,
# allowing any browser visitor to read or delete any row in any table.
# The anon key is safe to expose in frontend code; RLS policies
# enforce access control at the database level.
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
